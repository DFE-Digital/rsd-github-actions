{
  "disallowedPackages": [
    {
      "name": "MassTransit",
      "rules": [
        {
          "versionConstraint": ">8.5.10",
          "environments": [ "development", "test", "production" ],
          "message": "MassTransit must be v8.5.10 or less."
        }
      ]
    },
    {
